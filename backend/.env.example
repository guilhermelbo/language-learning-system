# LLM Provider: "ollama" (default) or "openai_compatible"
LLM_PROVIDER=ollama

# Model name
LLM_MODEL_NAME=mistral

# --- Ollama (LLM_PROVIDER=ollama) ---
OLLAMA_HOST=http://localhost:11434

# --- OpenAI-compatible (LLM_PROVIDER=openai_compatible) ---
# Qwen via Ollama OpenAI compat:
# LLM_PROVIDER=openai_compatible
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL_NAME=qwen2.5:7b

# Qwen via vLLM:
# LLM_PROVIDER=openai_compatible
# LLM_BASE_URL=http://localhost:8000/v1
# LLM_API_KEY=EMPTY
# LLM_MODEL_NAME=Qwen/Qwen2.5-7B-Instruct

# Remote OpenAI-compatible (e.g. Together AI, Groq):
# LLM_PROVIDER=openai_compatible
# LLM_BASE_URL=https://api.together.xyz/v1
# LLM_API_KEY=your-key-here
# LLM_MODEL_NAME=Qwen/Qwen2.5-72B-Instruct-Turbo

LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024

# Other services
STT_API_URL=http://localhost:8001
TTS_API_URL=http://localhost:8002
PIPER_MODEL_PATH=pt_BR-faber-medium.onnx
